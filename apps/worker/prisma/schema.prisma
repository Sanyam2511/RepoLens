generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RepoAnalysis {
  id        String   @id @default(uuid())
  repoUrl   String   @unique
  commitSha String?
  graphJson Json
  nodeCount Int
  edgeCount Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
